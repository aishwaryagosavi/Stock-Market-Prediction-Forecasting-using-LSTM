# ============================================
# Stock Market Prediction Using Stacked LSTM
# ============================================

# Importing libraries
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import tensorflow as tf
from sklearn.preprocessing import MinMaxScaler

# ============================================
# LOAD DATA
# ============================================

tg = pd.read_csv("https://raw.githubusercontent.com/mwitiderrick/stockprice/master/NSE-TATAGLOBAL.csv")
print("Dataset loaded successfully")
print(f"Shape: {tg.shape}")
tg.head()
# ============================================
# BASIC EXPLORATION
# ============================================

print("\nBasic Statistics:")
tg.describe()

# Check for null values
NAN = [(c, tg[c].isnull().mean()*100) for c in tg]
NAN = pd.DataFrame(NAN, columns=['column_name', 'percentage'])
print("\nNull Values:")
print(NAN)

# ============================================
# SORT BY DATE
# ============================================

srt = tg.sort_values(by='Date')
srt.reset_index(inplace=True)
print("\nData sorted by date")
srt.head()

# ============================================
# VISUALISE CLOSING PRICE
# ============================================

plt.figure(figsize=(12, 6))
plt.plot(srt['Date'], srt['Close'], color='steelblue')
plt.title('Tata Global — Closing Price Over Time', fontsize=14)
plt.xlabel('Date')
plt.ylabel('Closing Price (INR)')
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()
# ============================================
# FEATURE SCALING
# ============================================

close_srt = srt['Close']

# MinMaxScaler scales values between 0 and 1
# Neural networks train better on scaled data
scaler = MinMaxScaler(feature_range=(0, 1))
close_srt = scaler.fit_transform(np.array(close_srt).reshape(-1, 1))

print(f"\nScaled data shape: {close_srt.shape}")

# ============================================
# TRAIN TEST SPLIT
# ============================================

train_size = int(len(close_srt) * 0.7)
test_size = len(close_srt) - train_size

train_data = close_srt[0:train_size, :]
test_data = close_srt[train_size:len(close_srt), :1]

print(f"Train size: {train_data.shape}")
print(f"Test size: {test_data.shape}")
# ============================================
# CREATE DATASET FUNCTION — FIXED
# ============================================

# This function creates sequences of 'time_step' days
# to predict the next day's price
# BUG FIX: return statement moved outside the for loop

def create_dataset(dataset, time_step=1):
    dataX, dataY = [], []
    for i in range(len(dataset) - time_step - 1):
        a = dataset[i:(i + time_step), 0]
        dataX.append(a)
        dataY.append(dataset[i + time_step, 0])
    return np.array(dataX), np.array(dataY)  # ← outside loop

# ============================================
# RESHAPE DATA
# ============================================

time_step = 100
X_train, y_train = create_dataset(train_data, time_step)
X_test, y_test = create_dataset(test_data, time_step)

print(f"\nX_train shape: {X_train.shape}")
print(f"y_train shape: {y_train.shape}")
print(f"X_test shape: {X_test.shape}")
print(f"y_test shape: {y_test.shape}")

# Reshape for LSTM — needs 3D input (samples, timesteps, features)
X_train = X_train.reshape(X_train.shape[0], X_train.shape[1], 1)
X_test = X_test.reshape(X_test.shape[0], X_test.shape[1], 1)

print(f"\nReshaped X_train: {X_train.shape}")
print(f"Reshaped X_test: {X_test.shape}")
# ============================================
# BUILD STACKED LSTM MODEL
# ============================================

from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, LSTM

model = Sequential()

# 3 stacked LSTM layers — each learns more complex patterns
model.add(LSTM(50, return_sequences=True, input_shape=(100, 1)))
model.add(LSTM(50, return_sequences=True))
model.add(LSTM(50))
model.add(Dense(1))

model.compile(loss='mean_squared_error', optimizer='adam')
model.summary()

# ============================================
# TRAIN THE MODEL
# ============================================

print("\nTraining model...")
history = model.fit(
    X_train, y_train,
    validation_data=(X_test, y_test),
    epochs=60,
    batch_size=64,
    verbose=1
)
# ============================================
# EVALUATE PERFORMANCE
# ============================================

import math
from sklearn.metrics import mean_squared_error

train_predict = model.predict(X_train)
test_predict = model.predict(X_test)

# Inverse transform to get actual price values
train_predict = scaler.inverse_transform(train_predict)
test_predict = scaler.inverse_transform(test_predict)
y_train_actual = scaler.inverse_transform(y_train.reshape(-1, 1))
y_test_actual = scaler.inverse_transform(y_test.reshape(-1, 1))

train_rmse = math.sqrt(mean_squared_error(y_train_actual, train_predict))
test_rmse = math.sqrt(mean_squared_error(y_test_actual, test_predict))

print(f"\nTrain RMSE: {train_rmse:.4f}")
print(f"Test RMSE: {test_rmse:.4f}")
print(f"Average stock price: {tg['Close'].mean():.2f}")
print(f"Error as % of average price: {(test_rmse/tg['Close'].mean())*100:.2f}%")
# ============================================
# VISUALISE PREDICTIONS VS ACTUAL
# ============================================

plt.figure(figsize=(14, 6))

# Plot actual prices
plt.plot(scaler.inverse_transform(close_srt), 
         label='Actual Price', color='steelblue')

# Plot train predictions
train_predict_plot = np.empty_like(close_srt)
train_predict_plot[:, :] = np.nan
train_predict_plot[time_step:len(train_predict) + time_step, :] = train_predict
plt.plot(train_predict_plot, label='Train Prediction', color='green')

# Plot test predictions
test_predict_plot = np.empty_like(close_srt)
test_predict_plot[:, :] = np.nan
test_predict_plot[len(train_predict) + (time_step * 2) + 1:len(close_srt) - 1, :] = test_predict
plt.plot(test_predict_plot, label='Test Prediction', color='red')

plt.title('Stock Price Prediction — Actual vs Predicted', fontsize=14)
plt.xlabel('Time')
plt.ylabel('Stock Price (INR)')
plt.legend()
plt.tight_layout()
plt.show()
# ============================================
# PREDICT NEXT 30 DAYS
# ============================================

print("\nPredicting next 30 days...")

# Use last 100 days as input
pred_input = test_data[len(test_data) - time_step:].reshape(1, -1)
temp_input = list(pred_input[0])

future_predictions = []
for i in range(30):
    x_input = np.array(temp_input[-100:]).reshape(1, 100, 1)
    pred = model.predict(x_input, verbose=0)
    future_predictions.append(pred[0][0])
    temp_input.append(pred[0][0])

# Inverse transform future predictions
future_predictions = scaler.inverse_transform(
    np.array(future_predictions).reshape(-1, 1)
)

plt.figure(figsize=(10, 5))
plt.plot(future_predictions, marker='o', color='coral', linewidth=2)
plt.title('Stock Price Forecast — Next 30 Days', fontsize=14)
plt.xlabel('Days Ahead')
plt.ylabel('Predicted Price (INR)')
plt.tight_layout()
plt.show()

print("\nPredicted prices for next 30 days:")
for i, price in enumerate(future_predictions):
    print(f"Day {i+1}: INR {price[0]:.2f}")
